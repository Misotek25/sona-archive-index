# Python .gitignore file

# Byte-compiled / optimized / DLL files
__pycache__/
*.py[cod]
*.so

# Virtual environment
.env/
.venv/
venv/

# IDE files
.vscode/
.idea/
*.sublime-project
*.sublime-workspace

# Database files
data/sona.db

# Visualization outputs
*.png
*.jpg
*.jpeg
*.svg
*.pdf

# Temporary files
*~
*.tmp
*.temp
